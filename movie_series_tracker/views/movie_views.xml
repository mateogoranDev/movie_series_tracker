<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_movie_media_list" model="ir.ui.view">
        <field name="name">movie.media.list</field>
        <field name="model">movie.media</field>
        <field name="arch" type="xml">
            <list string="Mis Películas y Series">
                <field name="name"/>
                <field name="media_type" widget="badge" decoration-info="media_type == 'movie'" decoration-warning="media_type == 'series'"/>
                <field name="release_year" options="{'format': False}"/>
                <field name="genre_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="rating" widget="priority"/>
                <field name="watched" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_movie_media_kanban" model="ir.ui.view">
        <field name="name">movie.media.kanban</field>
        <field name="model">movie.media</field>
        <field name="arch" type="xml">
            <kanban default_group_by="media_type" class="o_kanban_mobile">
                <field name="id"/>
                <field name="name"/>
                <field name="release_year"/>
                <field name="genre_ids"/> 
                <field name="rating"/>
                <field name="watched"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex p-2 w-100">
                            <div class="o_kanban_image me-3" style="width: 80px; height: 110px; flex-shrink: 0; position: relative;">
                                <t t-if="record.image.raw_value">
                                    <field name="image" widget="image" 
                                           options="{'preview_image': 'image'}" 
                                           class="w-100 h-100 object-fit-cover rounded shadow"
                                           style="transition: transform 0.2s ease-in-out, z-index 0.1s; position: relative; z-index: 1; transform-origin: center;"
                                           onmouseover="this.style.transform='scale(2.3)'; this.style.zIndex='99999';"
                                           onmouseout="this.style.transform='scale(1)'; this.style.zIndex='1';" />
                                </t>
                                <t t-else="">
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-200 rounded text-muted">🎬</div>
                                </t>
                            </div>
                            <div class="d-flex flex-column justify-content-between flex-grow-1">
                                <div>
                                    <div class="fw-bold fs-5 text-truncate"><field name="name"/></div>
                                    <div class="text-muted small">
                                        <field name="release_year" options="{'format': False}"/> 
                                        <t t-if="record.genre_ids.raw_value"> • <field name="genre_ids" widget="many2many_tags"/></t>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center justify-content-between mt-2">
                                    <field name="rating" widget="priority"/>
                                    <field name="watched" widget="boolean_toggle"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_movie_media_form" model="ir.ui.view">
        <field name="name">movie.media.form</field>
        <field name="model">movie.media</field>
        <field name="arch" type="xml">
            <form string="Película / Serie">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_fetch_tmdb_info" 
                                string="Buscar y Autocompletar 🎬" 
                                type="object" 
                                class="oe_highlight btn-primary"/>
                    </div>

                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image', 'zoom': True, 'zoom_delay': 200, 'size': [150, 200]}"/>

                    <div class="oe_title">
                        <label for="name" string="Título de la obra"/>
                        <h1>
                            <field name="name" placeholder="Ej. Inception, Matrix, Breaking Bad..."/>
                        </h1>
                    </div>

                    <div class="card bg-light my-3" invisible="tmdb_api_key != False">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <div style="flex-grow: 1; min-width: 250px;">
                                    <h6 class="card-title mb-1">🔑 Configuración de la API Key (Solo verás esto la primera vez)</h6>
                                    <p class="text-muted small mb-0">Introduce tu clave para activar el buscador inteligente en todo el catálogo.</p>
                                </div>
                                <div>
                                    <button name="action_tmdb_signup" 
                                            string="🌐 Crear cuenta gratis en TMDB" 
                                            type="object" 
                                            class="btn btn-outline-secondary btn-sm"/>
                                </div>
                            </div>
                            <hr class="my-2"/>
                            <group class="m-0 p-0">
                                <field name="tmdb_api_key" password="True" placeholder="Pega aquí tu API Key de 32 caracteres y guarda la película..."/>
                            </group>
                        </div>
                    </div>

                    <group>
                        <group name="main_info">
                            <field name="media_type"/>
                            <field name="release_year" options="{'format': False}"/>
                            <field name="genre_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create': True}"/>
                        </group>
                        <group name="rating_info">
                            <field name="rating" widget="priority"/>
                            <field name="watched" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sinopsis" name="synopsis_page">
                            <field name="synopsis" placeholder="La sinopsis se descargará automáticamente al buscar..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_movie_media_search" model="ir.ui.view">
        <field name="name">movie.media.search</field>
        <field name="model">movie.media</field>
        <field name="arch" type="xml">
            <search string="Buscar Películas y Series">
                <field name="name" string="Título"/>
                <filter string="Películas" name="filter_movies" domain="[('media_type', '=', 'movie')]"/>
                <filter string="Series" name="filter_series" domain="[('media_type', '=', 'series')]"/>
                <group expand="0" string="Agrupar por...">
                    <filter string="Tipo" name="group_by_type" context="{'group_by': 'media_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_movie_media" model="ir.actions.act_window">
        <field name="name">Mi Catálogo</field>
        <field name="res_model">movie.media</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_group_by_type': 1}</field> 
    </record>

    <menuitem id="menu_movie_tracker_root" name="Cine Tracker"/>
    <menuitem id="menu_movie_media" name="Películas y Series" parent="menu_movie_tracker_root" action="action_movie_media" sequence="10"/>

</odoo>